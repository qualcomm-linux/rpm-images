<!-- Kiwi image description for CentOS Stream 10 (aarch64) on Qualcomm RB3 Gen2. -->
<!-- See https://osinside.github.io/kiwi/ for kiwi documentation.              -->
<image schemaversion="7.6" name="centos-stream10-aarch64">

  <description type="system">
    <author>Qualcomm Technologies, Inc.</author>
    <contact>linux@qualcomm.com</contact>
    <specification>CentOS Stream 10 disk image for Qualcomm RB3 Gen2 (aarch64)</specification>
  </description>

  <preferences>
    <version>10.0.0</version>
    <packagemanager>dnf4</packagemanager>
    <!-- efipartsize : ESP size in MiB                                  -->
    <type image="oem"
          filesystem="ext4"
          firmware="efi"
          efipartsize="512"
          target_blocksize="4096"
          kernelcmdline="clk_ignore_unused pd_ignore_unused audit=0 root=PARTLABEL=rootfs rootwait rw deferred_probe_timeout=60 console=ttyMSM0,115200 qcom_scm.download_mode=1">
      <bootloader name="grub2" timeout="5"/>
      <oemconfig>
        <!-- Automatically grow the root partition to fill the disk on first boot -->
        <oem-resize>true</oem-resize>
        <oem-swap>false</oem-swap>
      </oemconfig>
    </type>
  </preferences>

  <!-- EPEL 10 - provides dracut-kiwi-oem-repart, pv, and other extras -->
  <!-- imageinclude=false: build-time only, not baked into the image    -->
  <repository type="rpm-md" alias="epel10" imageinclude="false">
    <source path="https://dl.fedoraproject.org/pub/epel/10/Everything/aarch64/"/>
  </repository>

  <repository type="rpm-md" alias="centos-stream10-baseos" imageinclude="true">
    <source path="https://mirror.stream.centos.org/10-stream/BaseOS/aarch64/os/"/>
  </repository>

  <repository type="rpm-md" alias="centos-stream10-appstream" imageinclude="true">
    <source path="https://mirror.stream.centos.org/10-stream/AppStream/aarch64/os/"/>
  </repository>

  <repository type="rpm-md" alias="centos-stream10-crb" imageinclude="true">
    <source path="https://mirror.stream.centos.org/10-stream/CRB/aarch64/os/"/>
  </repository>

  <!-- Bootstrap packages installed first to set up the chroot -->
  <!-- Adapted from https://github.com/OSInside/kiwi-descriptions centos-09.0 -->
  <packages type="bootstrap">
    <package name="filesystem"/>
    <package name="basesystem"/>
    <package name="grub2-efi-aa64" arch="aarch64"/>
    <package name="grub2-efi-aa64-modules" arch="aarch64"/>
    <package name="shim-aa64" arch="aarch64"/>
  </packages>

  <!-- Image packages -->
  <packages type="image">
    <!-- Networking -->
    <package name="NetworkManager"/>
    <package name="NetworkManager-wifi"/>
    <package name="iproute"/>
    <package name="rfkill"/>
    <package name="wireless-regdb"/>
    <package name="wpa_supplicant"/>
    <package name="bluez"/>

    <!-- Firmware -->
    <package name="atheros-firmware"/>
    <package name="linux-firmware"/>
    <package name="qcom-firmware"/>

    <package name="kernel"/>
    <package name="kmod"/>
    <package name="dracut"/>
    <!-- Required by kiwi for oem image type (first-boot partition resize) -->
    <package name="dracut-kiwi-oem-repart"/>

    <package name="bash"/>
    <package name="coreutils"/>
    <package name="sudo"/>
    <package name="systemd"/>
    <package name="vim-minimal"/>
    <package name="wget"/>

    <package name="dosfstools"/>
    <package name="e2fsprogs"/>
    <package name="gdisk"/>
    <!-- pv (pipe viewer) - required by dracut-kiwi-lib; from EPEL 10 -->
    <package name="pv"/>

    <package name="openssh-clients"/>
    <package name="openssh-server"/>

    <package name="fwupd"/>
    <package name="pciutils"/>
    <package name="usbutils"/>
    <package name="v4l-utils"/>

    <package name="pipewire"/>
    <package name="wireplumber"/>
    <package name="pipewire-pulseaudio"/>
    <package name="alsa-utils"/>

    <package name="libcamera-tools"/>
    <package name="libcamera-v4l2"/>
  </packages>

</image>
